generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PersonaMode {
  REAL
  ALTER_EGO
}

enum ClipVisibility {
  PUBLIC
  FOLLOWERS
  PRIVATE
}

enum ModerationStatus {
  PENDING
  APPROVED
  REJECTED
  SHADOW_LIMITED
}

enum ChallengeKind {
  MIRROR_MOMENT
  CAMPUS_DUEL
  WORLD_DROP
  BRAND
}

enum DuelStatus {
  OPEN
  LIVE
  SCORING
  COMPLETE
  CANCELLED
}

enum TokenKind {
  EARN
  SPEND
  PURCHASE
  REFUND
  ADMIN_ADJUST
}

enum MatchStatus {
  SUGGESTED
  DUEL_CREATED
  HEART_PENDING
  CHAT_UNLOCKED
  DISMISSED
}

model User {
  id              String        @id @default(cuid())
  firebaseUid     String        @unique
  phone           String?       @unique
  email           String?       @unique
  username        String        @unique
  displayName     String
  dateOfBirth     DateTime?
  avatarUrl       String?
  campusId        String?
  city            String?
  personaMode     PersonaMode   @default(REAL)
  moderationState ModerationStatus @default(APPROVED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  campus          Campus?       @relation(fields: [campusId], references: [id])
  clips           Clip[]
  wallet          TokenWallet?
  settings        UserSettings?
  vibeDna         VibeDna?
  lifeStamps      LifeStamp[]
  alterEgo        AlterEgo?
  reportsMade     Report[]      @relation("Reporter")
  reportsAgainst  Report[]      @relation("ReportedUser")
  sentMessages    Message[]
  sessions        UserSession[]
  comments        Comment[]
}

model UserSettings {
  userId             String   @id
  lowDataMode        Boolean  @default(false)
  motionSensitivity  Int      @default(72)
  privateProfile     Boolean  @default(false)
  allowMotionMatch   Boolean  @default(true)
  notifyWorldDrop    Boolean  @default(true)
  notifyDuels        Boolean  @default(true)
  notifyMatches      Boolean  @default(true)
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id          String   @id @default(cuid())
  userId      String
  deviceName  String?
  ipHash      String?
  lastSeenAt  DateTime @default(now())
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campus {
  id        String   @id @default(cuid())
  name      String
  city      String
  state     String?
  country   String   @default("India")
  users     User[]
  createdAt DateTime @default(now())

  @@unique([name, city])
}

model Clip {
  id               String           @id @default(cuid())
  creatorId        String
  caption          String
  challengeTag     String?
  visibility       ClipVisibility   @default(PUBLIC)
  moderationStatus ModerationStatus @default(PENDING)
  durationMs       Int
  vibeScore        Int              @default(0)
  motionVector     Json
  soundAlchemy     Json
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  creator          User             @relation(fields: [creatorId], references: [id])
  assets           ClipAsset[]
  metrics          ClipMetric?
  comments         Comment[]
  reactions        ClipReaction[]
  duelSubmissions  DuelSubmission[]
  worldDropEntries WorldDropEntry[]
  reports          Report[]
}

model ClipAsset {
  id        String   @id @default(cuid())
  clipId    String
  kind      String
  url       String
  r2Key     String?
  mimeType  String
  width     Int?
  height    Int?
  createdAt DateTime @default(now())

  clip      Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
}

model ClipMetric {
  clipId   String @id
  likes    Int    @default(0)
  comments Int    @default(0)
  shares   Int    @default(0)
  saves    Int    @default(0)
  remixes  Int    @default(0)
  views    Int    @default(0)

  clip     Clip   @relation(fields: [clipId], references: [id], onDelete: Cascade)
}

model ClipReaction {
  id        String   @id @default(cuid())
  clipId    String
  userId    String
  kind      String
  createdAt DateTime @default(now())

  clip      Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)

  @@unique([clipId, userId, kind])
}

model Comment {
  id        String   @id @default(cuid())
  clipId    String
  userId    String
  body      String
  likes     Int      @default(0)
  createdAt DateTime @default(now())

  clip      Clip     @relation(fields: [clipId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  @@id([followerId, followingId])
}

model Challenge {
  id           String        @id @default(cuid())
  kind         ChallengeKind
  title        String
  prompt       String
  sponsorName  String?
  tokenReward  Int           @default(0)
  startsAt     DateTime?
  endsAt       DateTime?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())

  duels        Duel[]
}

model Duel {
  id          String     @id @default(cuid())
  challengeId String
  status      DuelStatus @default(OPEN)
  campusId    String?
  startsAt    DateTime?
  endsAt      DateTime?
  createdAt   DateTime   @default(now())

  challenge   Challenge  @relation(fields: [challengeId], references: [id])
  participants DuelParticipant[]
  submissions DuelSubmission[]
}

model DuelParticipant {
  id        String   @id @default(cuid())
  duelId    String
  userId    String
  hearted   Boolean  @default(false)
  joinedAt  DateTime @default(now())

  duel      Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)

  @@unique([duelId, userId])
}

model DuelSubmission {
  id          String   @id @default(cuid())
  duelId      String
  userId      String
  clipId      String
  score       Json
  totalScore  Int
  createdAt   DateTime @default(now())

  duel        Duel     @relation(fields: [duelId], references: [id], onDelete: Cascade)
  clip        Clip     @relation(fields: [clipId], references: [id])
}

model VibeDna {
  userId      String   @id
  vector      Json
  strand      Json
  clipCount   Int      @default(0)
  generatedAt DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LifeStamp {
  id        String   @id @default(cuid())
  userId    String
  kind      String
  title     String
  detail    String?
  clipId    String?
  earnedAt  DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TokenWallet {
  userId    String   @id
  balance   Int      @default(0)
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ledger    TokenLedger[]
}

model TokenLedger {
  id          String    @id @default(cuid())
  walletUserId String
  kind        TokenKind
  amount      Int
  reason      String
  referenceId String?
  idempotencyKey String? @unique
  createdAt   DateTime  @default(now())

  wallet      TokenWallet @relation(fields: [walletUserId], references: [userId], onDelete: Cascade)
}

model StoreItem {
  id          String   @id @default(cuid())
  sku         String   @unique
  title       String
  tokenPrice  Int?
  moneyPricePaise Int?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Purchase {
  id          String   @id @default(cuid())
  userId      String
  sku         String
  amountPaise Int
  provider    String
  providerRef String?
  status      String
  createdAt   DateTime @default(now())
}

model WorldDrop {
  id          String   @id @default(cuid())
  challengeId String
  title       String
  startsAt    DateTime
  endsAt      DateTime
  supercutUrl String?
  createdAt   DateTime @default(now())

  entries     WorldDropEntry[]
}

model WorldDropEntry {
  id          String   @id @default(cuid())
  worldDropId String
  userId      String
  clipId      String
  rank        Int?
  score       Int
  createdAt   DateTime @default(now())

  worldDrop   WorldDrop @relation(fields: [worldDropId], references: [id], onDelete: Cascade)
  clip        Clip      @relation(fields: [clipId], references: [id])

  @@unique([worldDropId, userId])
}

model MotionMatch {
  id          String      @id @default(cuid())
  userAId     String
  userBId     String
  status      MatchStatus @default(SUGGESTED)
  compatibility Int
  duelId      String?
  chatId      String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userAId, userBId])
}

model Chat {
  id        String    @id @default(cuid())
  matchId   String    @unique
  createdAt DateTime  @default(now())
  messages  Message[]
}

model Message {
  id        String   @id @default(cuid())
  chatId    String
  senderId  String
  body      String
  createdAt DateTime @default(now())

  chat      Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id])
}

model AlterEgo {
  userId      String   @id
  username    String   @unique
  displayName String
  avatarUrl   String?
  unlockedAt  DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Report {
  id             String   @id @default(cuid())
  reporterId     String
  reportedUserId String?
  clipId         String?
  reason         String
  status         String   @default("OPEN")
  createdAt      DateTime @default(now())

  reporter       User     @relation("Reporter", fields: [reporterId], references: [id])
  reportedUser   User?    @relation("ReportedUser", fields: [reportedUserId], references: [id])
  clip           Clip?    @relation(fields: [clipId], references: [id])
}

model BrandCampaign {
  id          String   @id @default(cuid())
  brandName   String
  title       String
  budgetPaise Int
  startsAt    DateTime
  endsAt      DateTime
  createdAt   DateTime @default(now())
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  payload   Json
  createdAt DateTime @default(now())
}
